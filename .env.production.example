# Image settings for docker-compose.prod.yml
BACKEND_IMAGE=ghcr.io/tenon-nonet/game-wiki-backend
FRONTEND_IMAGE=ghcr.io/tenon-nonet/game-wiki-frontend
IMAGE_TAG=release

# Application settings
DB_NAME=gamewiki
DB_USER=gamewiki_user
DB_PASSWORD=<set-a-strong-password>
JWT_SECRET=<set-a-long-random-secret>
ANTHROPIC_API_KEY=<set-your-anthropic-api-key>

